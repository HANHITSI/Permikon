{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Permikon",
  "version": "0.2.0",
  "identifier": "app.permikon",
  "build": {
    "frontendDist": "../public",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Permikon",
        "width": 1000,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "dragDropEnabled": true
      }
    ],
    "security": {}
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "deb", "rpm", "appimage", "dmg"],
    "icon": ["../public/logo.png"]
  }
}
